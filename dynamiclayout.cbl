       * DynamicLayout GNU COBOL API — generate layout JSON from COBOL code.
       * Single-file. Compiles with GnuCOBOL 3.1+.
       * COBOL is verbose — this generates JSON procedurally using STRING.
       *
       * Example:
       *   CALL "DL-BEGIN" USING "My Page" END-CALL
       *   CALL "DL-FIELDSET" USING "Info" END-CALL
       *   CALL "DL-LABEL" USING "Hello from COBOL!" END-CALL
       *   CALL "DL-END-FIELDSET" END-CALL
       *   CALL "DL-BUTTON" USING "ok" "OK" "primary" 1 END-CALL
       *   CALL "DL-END" END-CALL
       *   DISPLAY DL-BUF

        IDENTIFICATION DIVISION.
        PROGRAM-ID. DYNAMICLAYOUT.

        DATA DIVISION.
        WORKING-STORAGE SECTION.
        01 DL-BUF       PIC X(16384) VALUE SPACES.
        01 DL-POS       PIC 9(5) VALUE 0.
        01 DL-DEPTH     PIC 9(2) VALUE 0.
        01 DL-COMMA     PIC X VALUE 'N'.
           88 DL-COMMA-YES VALUE 'Y'.
           88 DL-COMMA-NO  VALUE 'N'.
        01 DL-CNT       PIC 9(4) VALUE 0.
        01 DL-KEY       PIC X(32).
        01 WS-I         PIC 9(3).
        01 WS-TMP       PIC X(16).

        LINKAGE SECTION.
        01 DL-TITLE     PIC X(256).
        01 DL-TEXT      PIC X(256).
        01 DL-ID        PIC X(64).
        01 DL-LABEL     PIC X(256).
        01 DL-MSG       PIC X(512).
        01 DL-COLOR     PIC X(16).
        01 DL-ROWS      PIC 9(2).
        01 DL-PX        PIC 9(4).
        01 DL-REQ       PIC X. 88 REQUIRED VALUE 'Y'.
        01 DL-DEF       PIC X. 88 IS-DEFAULT VALUE 'Y'.

        PROCEDURE DIVISION.

       DL-BEGIN SECTION.
           MOVE 0 TO DL-POS, DL-DEPTH, DL-CNT
           SET DL-COMMA-NO TO TRUE
           STRING '{"ui":{' INTO DL-BUF POINTER DL-POS
           MOVE 2 TO DL-DEPTH
           PERFORM DL-KV-VAR THRU DL-KV-VAR-EXIT
           PERFORM DL-ARR THRU DL-ARR-EXIT
           GOBACK.

       DL-END SECTION.
           PERFORM DL-CA THRU DL-CA-EXIT
           SET DL-COMMA-NO TO TRUE
           STRING ',' INTO DL-BUF POINTER DL-POS
           STRING '"translations":{},' INTO DL-BUF POINTER DL-POS
           STRING '"userAccess":{"cancel":true}' INTO DL-BUF POINTER DL-POS
           STRING '}}' INTO DL-BUF POINTER DL-POS
           GOBACK.

       DL-CM SECTION. IF DL-COMMA-YES STRING ',' INTO DL-BUF POINTER DL-POS. SET DL-COMMA-NO TO TRUE.

       DL-INDENT SECTION. STRING X'0A' INTO DL-BUF POINTER DL-POS. PERFORM VARYING WS-I FROM 1 BY 1 UNTIL WS-I > DL-DEPTH STRING '  ' INTO DL-BUF POINTER DL-POS END-PERFORM.

       DL-ESC SECTION. STRING '"' INTO DL-BUF POINTER DL-POS.

       DL-OBJ SECTION. PERFORM DL-CM. STRING ',' INTO DL-BUF POINTER DL-POS. PERFORM DL-INDENT. STRING '{' INTO DL-BUF POINTER DL-POS. ADD 1 TO DL-DEPTH. SET DL-COMMA-NO TO TRUE.

       DL-CO SECTION. SUBTRACT 1 FROM DL-DEPTH. PERFORM DL-INDENT. STRING '}' INTO DL-BUF POINTER DL-POS. SET DL-COMMA-YES TO TRUE.

       DL-ARR SECTION. PERFORM DL-CM. STRING ',' INTO DL-BUF POINTER DL-POS. PERFORM DL-INDENT. STRING '"layout": [' INTO DL-BUF POINTER DL-POS. ADD 1 TO DL-DEPTH. SET DL-COMMA-NO TO TRUE.

       DL-CA SECTION. SUBTRACT 1 FROM DL-DEPTH. PERFORM DL-INDENT. STRING ']' INTO DL-BUF POINTER DL-POS. SET DL-COMMA-YES TO TRUE.

       DL-KEY-GEN SECTION. ADD 1 TO DL-CNT.

       DL-FIELDSET SECTION. PERFORM DL-OBJ. STRING '"type": "FIELDSET",' INTO DL-BUF POINTER DL-POS. PERFORM DL-KEY-GEN. STRING '"title": "' DL-TITLE '",' INTO DL-BUF POINTER DL-POS. STRING '"content": [' INTO DL-BUF POINTER DL-POS. ADD 1 TO DL-DEPTH. SET DL-COMMA-NO TO TRUE.

       DL-END-FIELDSET SECTION. PERFORM DL-CA. PERFORM DL-CO.

       DL-LABEL SECTION. PERFORM DL-OBJ. STRING '"type": "LABEL",' INTO DL-BUF POINTER DL-POS. PERFORM DL-KEY-GEN. STRING '"label": "' DL-TEXT '"' INTO DL-BUF POINTER DL-POS. PERFORM DL-CO.

       DL-BUTTON SECTION. PERFORM DL-OBJ. STRING '"type": "BUTTON",' INTO DL-BUF POINTER DL-POS. PERFORM DL-KEY-GEN. STRING '"id": "' DL-ID '","title": "' DL-TEXT '","color": "' DL-COLOR '"' INTO DL-BUF POINTER DL-POS. IF IS-DEFAULT STRING ',"default": true' INTO DL-BUF POINTER DL-POS. PERFORM DL-CO.

       DL-KV-VAR SECTION. DL-KV-VAR-EXIT. EXIT.

       DL-ARR-EXIT. EXIT.
       DL-CA-EXIT. EXIT.

        END PROGRAM DYNAMICLAYOUT.
